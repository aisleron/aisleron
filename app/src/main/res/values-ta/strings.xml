    <string name="welcome_app_title">தொடங்குதல்</string>
    <string name="welcome_message">உங்கள் சாப்பிங் அனுபவத்தை எளிதாகவும் மேலும் ஒழுங்கமைக்கவும் உதவுவதில் நாங்கள் மகிழ்ச்சியடைகிறோம். தொடங்குவதற்கு, பின்வரும் விருப்பங்களில் ஒன்றைத் தேர்ந்தெடுக்கவும்:</string>
    <string name="welcome_add_own_product">&lt;h3&gt;உங்கள் சொந்த தயாரிப்புகளைச் சேர்க்கவும்&lt;/h3&gt; கடைகள், இடைகழிகள் மற்றும் தயாரிப்புகளைச் சேர்ப்பதன் மூலம் புதிதாக தனிப்பயனாக்கப்பட்ட சாப்பிங் பட்டியலை உருவாக்கத் தொடங்குங்கள்</string>
    <string name="welcome_load_sample_items">&lt;h3&gt;மாதிரி உருப்படிகளை ஏற்றவும்&lt;/h3&gt; ஆப்ச் எவ்வாறு செயல்படுகிறது என்பதை உணர, முன்பே நிரப்பப்பட்ட பட்டியலை முயற்சிக்கவும்</string>
    <string name="welcome_import_db">&lt;h3&gt;ஏற்கனவே இருக்கும் தரவுத்தளத்தை இறக்குமதி வெற்றி&lt;/h3&gt;</string>
    <string name="welcome_documentation">&lt;h3&gt;ஆவணத்தைப் பார்க்கவும்&lt;/h3&gt; ஆப்சின் அம்சங்களைப் பற்றி மேலும் அறிய Aisleron ஆவணங்களை ஆன்லைனில் பார்க்கவும்</string>
    <string name="welcome_title">ஐச்லெரோனுக்கு வரவேற்கிறோம்</string>
